# AI Engineering Track v2 - Environment Variables
# Copy this file to .env and fill in your API keys
# cp .env.example .env

# Required - OpenAI API (primary)
# https://platform.openai.com/settings/organization/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional - Anthropic (Claude models)
# https://platform.claude.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Optional - Google AI (Gemini models)
# https://aistudio.google.com/app/api-keys
GOOGLE_API_KEY=your-google-api-key-here

# Optional - Vector Database (Qdrant Cloud)
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# Optional - For local Ollama
OLLAMA_BASE_URL=http://localhost:11434

# AI_PROVIDER. "openai" or "ollama". Define models at scripts/model_config.py
AI_PROVIDER=ollama
